rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // M_Users collection: Extremely restrictive
    // Never allow client-side listing (GET /M_Users)
    // Only allow user to read their own metadata if they are logged in
    match /M_Users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false; // Only admin via API can write to this collection
    }

    // doctors collection: Public creation allowed
    // Only logged-in users (admins/staff) can read and update doctor info
    match /doctors/{doctorId} {
      allow create: if true; 
      allow read, update, delete: if isAuthenticated();
    }
    
    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
